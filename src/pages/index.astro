    <script>
      import initLandingAnimations from "../scripts/landing-animations";

      initLandingAnimations();

      const heroVideo =
        document.querySelector<HTMLVideoElement>("[data-hero-video]");

      if (heroVideo) {
        let hasLoadedVideo = false;
        const videoSource = heroVideo.dataset.videoSrc;
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        const connection = navigator.connection as
          | { saveData?: boolean }
          | undefined;

        const showHeroVideo = () => {
          heroVideo.classList.add("is-ready");
        };

        const loadHeroVideo = () => {
          if (
            hasLoadedVideo ||
            !videoSource ||
            prefersReducedMotion ||
            connection?.saveData
          ) {
            return;
          }

          hasLoadedVideo = true;

          const source = document.createElement("source");
          source.src = videoSource;
          source.type = "video/mp4";
          heroVideo.append(source);
          heroVideo.load();
          void heroVideo.play().catch(() => {
            heroVideo.classList.remove("is-ready");
          });
        };

        heroVideo.addEventListener("canplay", showHeroVideo, { once: true });
        heroVideo.addEventListener("playing", showHeroVideo, { once: true });
        heroVideo.addEventListener("error", () => {
          heroVideo.classList.remove("is-ready");
        });

        const loadOnInteraction = () => {
          loadHeroVideo();
        };

        window.addEventListener("pointerdown", loadOnInteraction, {
          once: true,
          passive: true,
        });
        window.addEventListener("keydown", loadOnInteraction, { once: true });

        if ("requestIdleCallback" in window) {
          window.requestIdleCallback(loadHeroVideo, { timeout: 2500 });
        } else {
          window.setTimeout(loadHeroVideo, 1600);
        }
      }
    </script>
