    avatar:
      "https://gravatar.com/avatar/6c6c3bed1c257ebdba662b12111724bc96ff804c41936045954acc6b60dc81b5?s=200&d=identicon",
  },
];

const vlog = {
  title: "2025 Vlog",
  url: "https://www.youtube.com/watch?v=CansA62TYXY",
  thumbnail: "https://img.youtube.com/vi/CansA62TYXY/maxresdefault.jpg",
};

const publicCalendarUrl =
  "https://calendar.google.com/calendar/embed?src=rf14d0k6cfstdnac3bigqv72ho%40group.calendar.google.com&ctz=Asia%2FTaipei";
const seoDescription =
  "SITCON Camp 2026 是由學生辦、給學生玩的資訊科技夏令營，將於 2026 年 7 月 8 日至 7 月 12 日在國立陽明交通大學舉辦。";
---

<Layout
  title="SITCON Camp 2026"
  description={seoDescription}
  image="/og-image.jpg"
>
  <div class="bg-paper text-ink">
    <header
      data-header
      class="site-header fixed inset-x-0 top-0 z-30 border-b border-line bg-paper/80 backdrop-blur-sm"
    >
      <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4"
      >
        <a
          href="#top"
          class="inline-flex"
          aria-label="SITCON Camp"
          data-hero-item
        >
          <SitconCampLogo class="h-7 w-auto invert md:h-8" aria-hidden="true" />
        </a>
        <nav class="hidden gap-6 text-sm md:flex">
          <a href="#about" class="hover:text-rust">關於</a>
          <a href="#recruit" class="hover:text-rust">加入工作人員</a>
          <a href="#timeline" class="hover:text-rust">時程</a>
          <a href="#team" class="hover:text-rust">工作人員</a>
          <a href="#faq" class="hover:text-rust">FAQ</a>
        </nav>
        <a
          href="https://i.sitcon.org/camp-recruit"
          target="_blank"
          rel="noreferrer"
          class="soft-button inline-flex items-center bg-rust px-4 py-2 text-sm font-medium text-cream hover:bg-rust-strong"
        >
          立即跳坑
        </a>
      </div>
    </header>

    <main id="top" class="relative z-10">
      <section
        data-hero-section
        class="relative overflow-hidden border-b border-line bg-paper text-cream"
      >
        <Image
          src={heroPosterImage}
          alt=""
          class="absolute inset-0 h-full w-full object-cover object-[62%_center] md:object-center"
          loading="eager"
          fetchpriority="high"
          widths={[640, 960, 1280, 1600]}
          sizes="100vw"
        />
        <video
          data-hero-video
          data-video-src={introVideo}
          class="hero-background-video absolute inset-0 h-full w-full object-cover object-[62%_center] md:object-center"
          autoplay
          muted
          loop
          playsinline
          preload="none"
          aria-hidden="true"
        ></video>
        <div class="absolute inset-0 bg-ink/56"></div>
        <div
          class="relative z-10 mx-auto flex min-h-screen max-w-6xl items-center px-6 py-20 md:py-28"
        >
          <div class="max-w-4xl">
            <p
              data-hero-item
              class="mb-4 text-sm tracking-[0.2em] text-cream/80"
            >
              第 10 屆
            </p>
            <h1
              data-hero-item
              class="max-w-4xl text-5xl font-semibold leading-tight md:text-7xl lg:text-[5.5rem]"
            >
              SITCON Camp 2026
            </h1>
            <p
              data-hero-item
              class="mt-6 max-w-4xl text-lg leading-8 text-cream/90 md:text-xl lg:max-w-5xl"
            >
              今夏，我們回來了。學生辦的、給學生玩的資訊科技夏令營，工作人員招募中。
            </p>
            <div data-hero-item class="mt-6 flex flex-wrap gap-4">
              <a
                href="https://i.sitcon.org/camp-recruit"
                target="_blank"
                rel="noreferrer"
                class="soft-button inline-flex items-center bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
              >
                工人跳坑表單
              </a>
              <a
                href="#about"
                class="soft-button inline-flex items-center border border-cream/45 bg-paper/14 px-5 py-3 text-cream backdrop-blur-md hover:bg-paper/22"
              >
                了解更多
              </a>
            </div>
            <div
              data-hero-item
              class="mt-5 flex flex-wrap items-center gap-3 text-sm text-cream/90"
            >
              <span class="font-medium">想報名嗎？</span>
              <a
                href="https://sitcon.org/ig"
                target="_blank"
                rel="noreferrer"
                class="soft-button inline-flex items-center bg-rust px-4 py-2 text-cream hover:bg-rust-strong"
              >
                追蹤 IG 獲得最新消息
              </a>
            </div>
            <div
              data-hero-item
              class="mt-8 flex flex-wrap gap-3 text-sm text-cream/90"
            >
              <div
                class="soft-chip border border-cream/35 bg-paper/18 px-3 py-2 shadow-sm backdrop-blur-md"
              >
                7/8 - 7/12
              </div>
              <div
                class="soft-chip border border-cream/35 bg-paper/18 px-3 py-2 shadow-sm backdrop-blur-md"
              >
                國立陽明交通大學
              </div>
              <div
                class="soft-chip border border-cream/35 bg-paper/18 px-3 py-2 shadow-sm backdrop-blur-md"
              >
                五天四夜
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="about" class="border-b border-line">
        <div
          data-reveal
          class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-2"
        >
          <div>
            <p class="mb-3 text-sm tracking-[0.2em] text-rust">ABOUT</p>
            <h2 class="text-3xl font-semibold">什麼是 SITCON Camp？</h2>
          </div>
          <div class="space-y-5 text-base leading-8 text-ink/90">
            <p>
              隨著資訊科學成為現代必備素養，各種入門語法與工具的學習資源已在網路上百花齊放。自
              2014 年起，SITCON
              夏令營陪伴無數對科技懷抱熱忱的學生走過多個年頭。為了因應學習資源的普及與時代的改變，SITCON
              Camp
              決定跳脫傳統入門導向的框架，將營隊重新定位為一場「探索型」與「導覽型」的資訊旅程。除了延續社群闖關、視界咖啡館與黑客松等經典互動，我們更期望將開源精神轉化為引路的星光，陪伴學員在浩瀚的資訊領域中，發掘真正屬於自己的專長與熱情。
            </p>
            <p>
              SITCON Camp
              今年聚焦於一個許多學子共同的迷惘：現今有很大一群人已經踏入資訊領域的門口，可能剛在課堂上學完
              Python、寫過幾行小程式，卻在面對資安、競程、AI、系統或是開源等龐大分支時，不知道下一步該往哪裡前進。因此，今年我們不只帶你印出「Hello
              World」，更要陪你尋找「What's
              Next?」。我們致力於服務這些已經具備基礎、卻渴望釐清各子領域實際面貌的學生，為你在迷惘的青春中提供一個最具啟發性的指路牌。
            </p>
            <p>
              為了達成這個理想，今年的課程迎來了一次瘋狂且大膽的嘗試——我們將以近似「Masterclass（大師課）」的形式重塑營隊體驗。在營期專屬的「主題日」中，將由該領域的專家親自帶路，從相對容易理解的切入點，直搗該領域最迷人、最具代表性的核心。無論是跳脫艱澀數學，親手完成資料前處理並微調（Fine-tune）出專屬的語言模型；還是在安全靶機環境中實作攻擊與防禦，體驗駭客尋找破綻的思維邏輯。透過短時間、高密度的實戰引導，學員將能快速抓到各領域的問題脈絡，在一天內確實觸碰資訊科學最迷人的那一面，並找到讓自己想持續鑽研的未來方向！
            </p>
          </div>
        </div>

        <section id="recruit" class="border-b border-line bg-cream/60">
          <div class="mx-auto max-w-6xl px-6 py-16">
            <div
              data-reveal
              class="grid gap-8 md:grid-cols-[1fr_2fr] md:items-start"
            >
              <div>
                <p class="mb-3 text-sm tracking-[0.2em] text-rust">RECRUIT</p>
                <h2 class="text-3xl font-semibold">一起把這屆 Camp 做出來</h2>
              </div>
              <div class="space-y-5 text-base leading-8 text-ink/90">
                <p>
                  每個活動的成功，皆仰賴在幕後默默付出的工作人員。如果你也想參與活動的籌備，和一群實力堅強且有想法的人一起共事，歡迎依照自己的專長與興趣加入我們。
                </p>
                <p>
                  各組招募資訊、截止日期與報名入口已整理在下面；完整招募說明請看招募文件
                </p>
                <div class="flex flex-wrap gap-4 pt-2">
                  <a
                    href="https://i.sitcon.org/camp-recruit"
                    target="_blank"
                    rel="noreferrer"
                    class="soft-button inline-flex items-center bg-rust px-5 py-3 text-cream hover:bg-rust-strong"
                  >
                    立即跳坑
                  </a>
                </div>
              </div>
            </div>

            <div
              data-stagger
              class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3"
            >
              {
                sortedRecruitTeams.map((team) => (
                  <article
                    data-stagger-item
                    class="soft-card overflow-hidden border border-line bg-paper shadow-[0_20px_40px_color-mix(in_srgb,var(--color-ink)_8%,transparent)]"
                  >
                    <Image
                      src={team.image}
                      alt={team.name}
                      class="h-44 w-full object-cover"
                      loading="lazy"
                    />
                    <div class="p-5">
                      <div class="flex items-start justify-between gap-4">
                        <h3 class="text-xl font-semibold">{team.name}</h3>
                        <span class="text-sm text-rust">{team.deadline}</span>
                      </div>
                      <p class="mt-4 text-sm leading-7 text-ink/90">
                        {team.description}
                      </p>
                      <a
                        href={team.link}
                        target="_blank"
                        rel="noreferrer"
                        class="soft-button mt-6 inline-block border border-line px-4 py-2 text-sm hover:bg-cream"
                      >
                        立即跳坑
                      </a>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </section>

        <section id="timeline" class="border-b border-line bg-sand/10">
          <div data-reveal class="mx-auto max-w-6xl px-6 py-16">
            <div class="grid gap-6 lg:grid-cols-[1fr_auto]">
              <div
                class="soft-card overflow-hidden border border-line bg-paper shadow-[0_20px_40px_color-mix(in_srgb,var(--color-ink)_8%,transparent)]"
              >
                <div
                  class="grid gap-8 px-6 py-10 md:grid-cols-[minmax(0,1.4fr)_auto] md:items-end md:px-8"
                >
                  <div>
                    <p class="mb-3 text-sm tracking-[0.2em] text-rust">
                      TIMELINE
                    </p>
                    <h2 class="text-3xl font-semibold">
                      重要時程都在公開行事曆
                    </h2>
                    <p class="mt-4 max-w-2xl text-base leading-8 text-ink/90">
                      想要參與籌備會議或查看重要時間節點嗎？工人招募、籌會時間、學員報名與營期更新都會同步整理在
                      SITCON Camp
                      的公開行事曆，SITCON秉持著開放原則，所有的會議都可以隨時旁聽或發表意見！
                    </p>
                  </div>
                  <a
                    href={publicCalendarUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="soft-button inline-flex items-center justify-center bg-rust px-6 py-3 text-base font-medium text-cream hover:bg-rust-strong"
                  >
                    開啟 Google Calendar
                  </a>
                </div>
              </div>

              <div
                class="soft-card flex flex-col justify-between overflow-hidden border border-line bg-paper px-8 py-10 shadow-[0_20px_40px_color-mix(in_srgb,var(--color-ink)_8%,transparent)]"
              >
                <p class="mb-4 text-sm tracking-[0.2em] text-rust">營期</p>
                <div>
                  <p class="text-6xl font-bold leading-none tracking-tight">
                    7 月 08 日
                  </p>
                  <p class="my-3 text-2xl font-light text-ink/40">
                    <span class="inline-block rotate-90">～</span>
                  </p>
                  <p class="text-6xl font-bold leading-none tracking-tight">
                    7 月 12 日
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="team" class="border-b border-line bg-sand/10">
          <div class="mx-auto max-w-6xl px-6 py-16">
            <p class="mb-3 text-sm tracking-[0.2em] text-rust">TEAM</p>
            <h2 class="text-3xl font-semibold">今年的坑主們</h2>
            <p class="mt-4 max-w-2xl text-base leading-8 text-ink/90">
              各組組長們，他們將帶領今年的各位組員們共同創造出這場 Camp
            </p>
            <div
              data-stagger
              class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
            >
              {
                staffMembers.map((member) => (
                  <article
                    data-stagger-item
                    class="soft-card border border-line bg-paper p-5 shadow-[0_16px_32px_color-mix(in_srgb,var(--color-ink)_8%,transparent)]"
                  >
                    <div class="flex items-center gap-4">
                      {member.avatar && (
                        <Image
                          src={member.avatar}
                          alt={member.name}
