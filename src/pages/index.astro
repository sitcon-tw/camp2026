    role: "課程活動組 組長",
    avatar:
      "https://gravatar.com/avatar/e087ca958a3115405b32e62072ff801b5dfcb4179607a1c56f20df88043e16ab?s=200&d=identicon",
  },
  {
    name: "Yoru",
    role: "開發組 組長",
    avatar:
      "https://gravatar.com/avatar/cdf78bfb55f7be52400da72e2b780ffc62af848476b998f80bbf287c67b231a7?s=200&d=identicon",
  },
  {
    name: "康喔",
    role: "紀錄組 組長",
    avatar:
      "https://gravatar.com/avatar/08b25778f9a9ca3f2591b4e859be426dbd075608d763daf4fdd244d48eb26f13?s=200&d=identicon",
  },
  {
    name: "阿公",
    role: "庶務組 組長",
    avatar:
      "https://gravatar.com/avatar/196e64709935c454b821b5de526e48cf790dbd78a0606642405a35ae592e63d2?s=200&d=identicon",
  },
  {
    name: "Lindy",
